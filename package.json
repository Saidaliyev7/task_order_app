{
  "name": "mf-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Microfrontend platform scaffold for shell, orders, and inventory apps",
  "scripts": {
    "dev:shell": "npm run dev --workspace @mf/shell",
    "dev:orders": "npm run dev --workspace @mf/orders",
    "dev:inventory": "npm run dev --workspace @mf/inventory",
    "dev:meals": "npm run dev --workspace @mf/meals",
    "dev": "concurrently -n shell,orders,inventory,meals \"npm:dev:shell\" \"npm:dev:orders\" \"npm:dev:inventory\" \"npm:dev:meals\"",
    "lint": "eslint --ext .ts,.tsx apps packages",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "build": "npm run build --workspaces ",
    "preview": "npm run preview --workspaces ",
    "analyze": "ANALYZE=true npm run build",
    "test": "vitest"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "vite": "7.1.7"
  }
}
